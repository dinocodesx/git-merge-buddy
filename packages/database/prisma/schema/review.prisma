model Review {
  id          String          @id @default(cuid())
  status      ReviewStatus    @default(PENDING)
  commitSha   String
  prNumber    Int

  // Metrics
  tokensUsed  Int?
  startedAt   DateTime?
  completedAt DateTime?

  // Output
  rawAnalysis String?         @db.Text
  errorReason String?         @db.Text

  // Relations
  repoId      String
  repository  Repository      @relation(fields: [repoId], references: [id])
  comments    ReviewComment[]

  // Timestamps
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("review")
}

model ReviewComment {
  id              String      @id @default(cuid())
  filePath        String
  lineNumber      Int
  content         String      @db.Text
  type            CommentType @default(SUGGESTION)
  priority        Priority    @default(MEDIUM)
  githubCommentId String? // The ID of the comment posted back to GitHub

  // Relations
  reviewId        String
  review          Review      @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt       DateTime    @default(now())

  @@map("review_comment")
}

enum ReviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum CommentType {
  BUG
  SUGGESTION
  SECURITY
  PERFORMANCE
  STYLE
  DOCUMENTATION
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
